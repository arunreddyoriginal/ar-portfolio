# =====================================================
# arunreddy.co — Environment Variables
# =====================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# Resend API key for contact form emails
# Get your free key at: https://resend.com
# Free tier: 3,000 emails/month
RESEND_API_KEY=re_your_key_here

# Email address that receives contact form submissions
CONTACT_EMAIL=arunreddy.co@gmail.com

# Your site URL (used for OG tags and canonical URLs)
NEXT_PUBLIC_SITE_URL=https://arunreddy.co
